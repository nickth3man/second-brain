# Orchestrator workspace (session state, not project code)
.slim/deepwork/

# .brain/ embeddings database — sqlite-vec binary blob, regenerable
.brain/embeddings.db
.brain/embeddings.db-*

# .brain/ cache — transient inference cache
.brain/cache/

# .brain/ snapshots — pre-rebuild backups (§12.6)
.brain/snapshots/

# .brain/ deadletter — failed extractions (keep folder, ignore contents)
.brain/deadletter/*
!.brain/deadletter/.gitkeep

# .brain/ quarantine — low-confidence extractions
.brain/quarantine/

# .brain/ golden — golden test set (populated later)
.brain/golden/

# .brain/ embedding swap temp dirs (§12.6 blue/green)
.brain/embeddings.new/
.brain/embeddings.rollback/

# .brain/ eval artifacts — L1-L4 metrics (regenerable)
.brain/evals/

# .brain/ logs — rotating structured logs (observability, §12.7)
.brain/logs/

# .brain/ state backups — transient write-then-backup
.brain/state.json.bak*

# Python virtual environment
.venv/

# Python bytecode
__pycache__/
*.pyc

# Python build artifacts (from `pip install -e .`)
*.egg-info/
build/
dist/

# Environment overrides
.env

# Local config overrides (never committed)
*.local.toml

# Tool caches
.mypy_cache/
.ruff_cache/
.pytest_cache/

# 00-inbox/ — user's private raw originals (keep folder, ignore contents, §12.8)
00-inbox/*
!00-inbox/.gitkeep

# 50-sources/ — AI-normalized markdown, per-user derived data
50-sources/*
!50-sources/.gitkeep

# 90-wiki/ — living topic wiki, per-user derived data
90-wiki/*
!90-wiki/.gitkeep

# .brain/ state — per-user topic graph + append-only audit log (regenerated on first run)
.brain/state.json
.brain/changelog.jsonl

# INDEX.md — auto-generated brain front door (regenerated on ingest)
INDEX.md

# Real config — contains the user's API key + model choices (gitignored).
# Copy config.example.toml -> config.toml and fill in your key.
config.toml